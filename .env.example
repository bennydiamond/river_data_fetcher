# Home Assistant Configuration
# Uncomment and set your Home Assistant long-lived access token
# HA_TOKEN=your_home_assistant_long_lived_token_here

# Home Assistant API base URL
HA_API_BASE_URL=http://192.168.0.250:8123/api

# Station configuration
STATION_NUMBER=030315

# Optional: override the graph URL directly
# GRAPH_URL=https://www.cehq.gouv.qc.ca/suivihydro/graphique.asp?noStation=030315

# Station display name pieces
STATION_NAME_PREFIX=Upton
# RIVER_NAME=Noire
RIVER_NAME_FALLBACK=Noire

# Optional: override graph sensor entity IDs.
# You can provide either "my_entity" or "sensor.my_entity".
# HA_FORECAST_ENTITY_ID=my_forecast_entity
# HA_ALERTS_ENTITY_ID=my_alerts_entity

# Optional: override the data URL directly
# DATA_URL=https://www.cehq.gouv.qc.ca/suivihydro/tableau.asp?NoStation=030315

# Logging Configuration  
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Remote syslog server (logs are NOT stored on disk)
SYSLOG_HOST=192.168.0.15
SYSLOG_PORT=514

# Embedded web server port
WEB_PORT=30315

# Backup directory path for persistent storage (cold-start fallback)
# Use relative path for docker-compose: ./graph_backup
# Use absolute path for Portainer: /data/graph_backup or /mnt/backups/graph
BACKUP_PATH=./graph_backup

# Nginx config path for web server
# Use relative path for docker-compose: ./nginx/nginx.conf
# Use absolute path for Portainer: /data/nginx/nginx.conf
NGINX_CONFIG_PATH=./nginx/nginx.conf

# Scheduler Intervals
# River Data Fetcher interval (in minutes, default 10)
FETCHER_INTERVAL_MINUTES=10

# Graph Downloader interval (in minutes, default 120 = 2 hours)
GRAPH_INTERVAL_MINUTES=120

# Backup interval (in hours, default 24)
BACKUP_INTERVAL_HOURS=24

# Flood prediction trigger threshold in m³/s (default 100.0)
# Set to 0 to disable prediction processing and forecast sensor emission
PREDICTION_THRESHOLD_M3S=100.0

# Set to false to disable smart alert generation while keeping forecast processing enabled
SMART_ALERTS_ENABLED=true

# Smart alert tuning
# Match forecast events against prior tracked events within this many hours
SMART_ALERT_MATCH_WINDOW_HOURS=4

# Trigger an update alert when peak flow changes by at least this many m³/s
SMART_ALERT_UPDATE_DELTA_M3S=30

# Only emit brand-new alerts for events starting within this many days ahead
SMART_ALERT_NEW_LOOKAHEAD_DAYS=1

# Advanced graph settings (optional and typically not needed for most users)
# BACKUP_DIR=/backup
# LAST_SUCCESS_FILE=/opt/graph_automation/last_success.json
# WEB_ROOT=/usr/share/nginx/html
